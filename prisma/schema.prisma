datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model Expense {
  id          String     @id @default(uuid())
  userId      String?
  user        User?      @relation(fields: [userId], references: [id])
  amount      Float
  item        String
  quantity    Int?
  description String
  category    String     @default("lainnya")
  rawInput    String
  source      String     @default("whatsapp")
  type        String     @default("expense")
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  PrintLogs   PrintLog[]
}

model PrintLog {
  id         String   @id @default(uuid())
  userId     String?
  user       User?    @relation(fields: [userId], references: [id])
  expenseId  String?
  expense    Expense? @relation(fields: [expenseId], references: [id])
  type       String   @default("receipt") // "receipt" or "monthly"
  printId    String   @unique
  metadata   String?  // JSON string
  createdAt  DateTime @default(now())
}

model Budget {
  id        String   @id @default(uuid())
  userId    String?
  user      User?    @relation(fields: [userId], references: [id])
  category  String   // Category name
  amount    Float    // Limit nominal
  month     Int?     // 1-12
  year      Int?     // e.g. 2024
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([category, month, year, userId], name: "category_month_year_userId")
}

model SharedBill {
  id          String             @id @default(uuid())
  userId      String?
  user        User?              @relation(fields: [userId], references: [id])
  subtotal    Float
  tax         Float
  service     Float
  total       Float
  taxRate     Float              @default(0)
  serviceRate Float              @default(0)
  createdAt   DateTime           @default(now())
  
  items       SharedBillItem[]
  members     SharedBillMember[]
}

model SharedBillItem {
  id           String     @id @default(uuid())
  billId       String
  bill         SharedBill @relation(fields: [billId], references: [id], onDelete: Cascade)
  name         String
  price        Float
  qty          Int
  assignedTo   String[]   // Array of member IDs (mapped from frontend)
}

model SharedBillMember {
  id           String     @id @default(uuid())
  billId       String
  bill         SharedBill @relation(fields: [billId], references: [id], onDelete: Cascade)
  memberId     String     // Original ID from frontend
  name         String
  subtotal     Float
  tax          Float
  service      Float
  total        Float
  paidAmount   Float      @default(0)
}

model User {
  id            String    @id @default(uuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  accounts      Account[]
  sessions      Session[]
  waToken         String?   @unique
  waNumber        String?   @unique
  waTokenUpdatedAt DateTime?
  expenses      Expense[]
  budgets       Budget[]
  sharedBills   SharedBill[]
  printLogs     PrintLog[]
}

model Account {
  id                 String  @id @default(uuid())
  userId             String
  type               String
  provider           String
  providerAccountId  String
  refresh_token      String?  @db.Text
  access_token       String?  @db.Text
  expires_at         Int?
  token_type         String?
  scope              String?
  id_token           String?  @db.Text
  session_state      String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(uuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

